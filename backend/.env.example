# ============================================================
# Leyer8 Backend — Variables de entorno
# ============================================================
# Copia este archivo a `.env` y completa los valores.
# El archivo `.env` NUNCA se sube al repo (está en .gitignore).

# Puerto local de desarrollo (Railway asigna el suyo en prod)
PORT=3000

# Entorno: development | production
NODE_ENV=development

# ------------------------------------------------------------
# NextDNS (Fase B)
# ------------------------------------------------------------
# Token de API de NextDNS. Obtenerlo en: Account → API
# Formato: 32 caracteres hexadecimales
NEXTDNS_API_KEY=

# ------------------------------------------------------------
# Firebase Admin (Fase B)
# ------------------------------------------------------------
# Credenciales de Firebase Service Account en formato JSON,
# todo en una sola línea (escapando los saltos de línea de la
# private_key como \n literales).
# Se obtiene en: Firebase Console → Project Settings →
# Service accounts → Generate new private key.
FIREBASE_SERVICE_ACCOUNT=
