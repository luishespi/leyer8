# ============================================================
# Leyer8 Monorepo — .gitignore
# ============================================================

# ---- macOS ----
.DS_Store
.AppleDouble
.LSOverride

# ---- IDEs / Editors ----
.idea/
.vscode/
*.iml
*.swp
*.swo

# ---- Environment / Secrets ----
.env
.env.local
.env.*.local
*.pem
*.key

# ---- Flutter / Dart (app/) ----
app/**/.dart_tool/
app/**/.packages
app/**/.pub-cache/
app/**/.pub/
app/**/build/
app/**/.flutter-plugins
app/**/.flutter-plugins-dependencies
app/**/pubspec.lock.bak
app/**/coverage/
app/**/doc/api/

# Android
app/android/**/gradle-wrapper.jar
app/android/.gradle
app/android/captures/
app/android/gradlew
app/android/gradlew.bat
app/android/local.properties
app/android/**/GeneratedPluginRegistrant.java
app/android/key.properties
app/android/**/*.keystore
app/android/**/*.jks
app/android/app/release/

# iOS
app/ios/**/*.mode1v3
app/ios/**/*.mode2v3
app/ios/**/*.moved-aside
app/ios/**/*.pbxuser
app/ios/**/*.perspectivev3
app/ios/**/*sync/
app/ios/**/.sconsign.dblite
app/ios/**/.tags*
app/ios/**/.vagrant/
app/ios/**/DerivedData/
app/ios/**/Icon?
app/ios/**/Pods/
app/ios/**/.symlinks/
app/ios/**/profile
app/ios/**/xcuserdata
app/ios/**/.generated/
app/ios/**/Flutter/App.framework
app/ios/**/Flutter/Flutter.framework
app/ios/**/Flutter/Flutter.podspec
app/ios/**/Flutter/Generated.xcconfig
app/ios/**/Flutter/ephemeral/
app/ios/**/Flutter/app.flx
app/ios/**/Flutter/app.zip
app/ios/**/Flutter/flutter_assets/
app/ios/**/Flutter/flutter_export_environment.sh
app/ios/**/ServiceDefinitions.json
app/ios/**/Runner/GeneratedPluginRegistrant.*

# Firebase (se agregan después cuando integres Firebase en Día 2)
app/android/app/google-services.json
app/ios/Runner/GoogleService-Info.plist
app/lib/firebase_options.dart

# ---- Node.js / TypeScript (backend/) ----
backend/node_modules/
backend/dist/
backend/build/
backend/coverage/
backend/.nyc_output/
backend/npm-debug.log*
backend/yarn-debug.log*
backend/yarn-error.log*
backend/.pnpm-debug.log*
backend/.env
backend/.env.*
!backend/.env.example

# ---- Logs generales ----
*.log
logs/